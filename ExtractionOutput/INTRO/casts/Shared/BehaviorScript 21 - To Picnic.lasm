on exitFrame
  [  0] pushint16 4 ............................. <4>
  [  3] pusharglistnoret 1 ...................... <4>
  [  5] extcall 1 ............................... cursor(4)
  [  7] pushcons 0 .............................. <"InitPicnic">
  [  9] pushcons 1 .............................. <"PICNIC">
  [ 11] pusharglistnoret 2 ...................... <"InitPicnic", "PICNIC">
  [ 13] extcall 3 ............................... go("InitPicnic", "PICNIC")
  [ 15] ret
end
