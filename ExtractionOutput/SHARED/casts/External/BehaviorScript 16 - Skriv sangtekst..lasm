on exitFrame
  [  0] getglobal 63 ............................ <gSkriver>
  [  2] pusharglist 1 ........................... <gSkriver>
  [  4] extcall 62 .............................. <objectp(gSkriver)>
  [  6] not ..................................... <not objectp(gSkriver)>
  [  7] jmpifz [ 14] ............................ if not objectp(gSkriver) then
  [ 10] pusharglistnoret 0 ...................... <>
  [ 12] extcall 60 .............................. InitPrinter()
  [ 14] getglobal 63 ............................ <gSkriver>
  [ 16] pusharglist 1 ........................... <gSkriver>
  [ 18] extcall 62 .............................. <objectp(gSkriver)>
  [ 20] not ..................................... <not objectp(gSkriver)>
  [ 21] jmpifz [ 24] ............................ if not objectp(gSkriver) then
  [ 24] ret
end
