on PuppetOffAndVisible
  [  0] pushint8 1 .............................. <1>
  [  2] setlocal 0
  [  4] getlocal 0
  [  6] pushint8 48 ............................. <48>
  [  8] lteq
  [  9] jmpifz [ 38] ............................ repeat with i = 1 to 48
  [ 12] getlocal 0 .............................. <i>
  [ 14] pusharglist 1 ........................... <i>
  [ 16] extcall 53 .............................. <sprite(i)>
  [ 18] pushint8 1 .............................. <1>
  [ 20] setobjprop 54 ........................... sprite(i).visible = 1
  [ 22] getlocal 0 .............................. <i>
  [ 24] pushzero ................................ <0>
  [ 25] pusharglistnoret 2 ...................... <i, 0>
  [ 27] extcall 55 .............................. puppetSprite(i, 0)
  [ 29] pushint8 1
  [ 31] getlocal 0
  [ 33] add
  [ 34] setlocal 0
  [ 36] endrepeat [  4]
  [ 38] ret
end
