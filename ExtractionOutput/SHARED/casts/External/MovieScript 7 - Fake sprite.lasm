on SetFakeSprite spriteNr
  [  0] getparam 0 .............................. <spriteNr>
  [  2] pushint8 10 ............................. <10>
  [  4] get 6 ................................... <the ink of sprite spriteNr>
  [  6] setlocal 0 .............................. ink = the ink of sprite spriteNr
  [  8] pushint8 48 ............................. <48>
  [ 10] getparam 0 .............................. <spriteNr>
  [ 12] pushint8 4 .............................. <4>
  [ 14] get 6 ................................... <the castNum of sprite spriteNr>
  [ 16] pushint8 4 .............................. <4>
  [ 18] set 6 ................................... set the castNum of sprite 48 to the castNum of sprite spriteNr
  [ 20] getparam 0 .............................. <spriteNr>
  [ 22] pushcons 0 .............................. <"FakeDot">
  [ 24] pushzero ................................ <0>
  [ 25] pushint8 10 ............................. <10>
  [ 27] get 9 ................................... <the number of member "FakeDot">
  [ 29] pushint8 4 .............................. <4>
  [ 31] set 6 ................................... set the castNum of sprite spriteNr to the number of member "FakeDot"
  [ 33] pushint8 48 ............................. <48>
  [ 35] getlocal 0 .............................. <ink>
  [ 37] pushint8 10 ............................. <10>
  [ 39] set 6 ................................... set the ink of sprite 48 to ink
  [ 41] getparam 0 .............................. <spriteNr>
  [ 43] pushzero ................................ <0>
  [ 44] pushint8 22 ............................. <22>
  [ 46] set 6 ................................... set the stretch of sprite spriteNr to 0
  [ 48] pushint8 48 ............................. <48>
  [ 50] pushzero ................................ <0>
  [ 51] pushint8 22 ............................. <22>
  [ 53] set 6 ................................... set the stretch of sprite 48 to 0
  [ 55] pushint8 48 ............................. <48>
  [ 57] getparam 0 .............................. <spriteNr>
  [ 59] pushint8 13 ............................. <13>
  [ 61] get 6 ................................... <the locH of sprite spriteNr>
  [ 63] pushint8 13 ............................. <13>
  [ 65] set 6 ................................... set the locH of sprite 48 to the locH of sprite spriteNr
  [ 67] pushint8 48 ............................. <48>
  [ 69] getparam 0 .............................. <spriteNr>
  [ 71] pushint8 14 ............................. <14>
  [ 73] get 6 ................................... <the locV of sprite spriteNr>
  [ 75] pushint8 14 ............................. <14>
  [ 77] set 6 ................................... set the locV of sprite 48 to the locV of sprite spriteNr
  [ 79] pushint8 48 ............................. <48>
  [ 81] pusharglist 1 ........................... <48>
  [ 83] extcall 53 .............................. <sprite(48)>
  [ 85] pushint8 1 .............................. <1>
  [ 87] setobjprop 54 ........................... sprite(48).visible = 1
  [ 89] getparam 0 .............................. <spriteNr>
  [ 91] pusharglist 1 ........................... <spriteNr>
  [ 93] extcall 53 .............................. <sprite(spriteNr)>
  [ 95] pushzero ................................ <0>
  [ 96] setobjprop 54 ........................... sprite(spriteNr).visible = 0
  [ 98] ret
end

