on InitPrinter
  [  0] getglobal 63 ............................ <gSkriver>
  [  2] pusharglist 1 ........................... <gSkriver>
  [  4] extcall 62 .............................. <objectp(gSkriver)>
  [  6] jmpifz [ 12] ............................ if objectp(gSkriver) then
  [  9] pushzero ................................ <0>
  [ 10] setglobal 63 ............................ gSkriver = 0
  [ 12] pushcons 0 .............................. <"PrintOMatic">
  [ 14] pusharglist 1 ........................... <"PrintOMatic">
  [ 16] extcall 65 .............................. <xtra("PrintOMatic")>
  [ 18] pusharglist 1 ........................... <xtra("PrintOMatic")>
  [ 20] extcall 64 .............................. <new(xtra("PrintOMatic"))>
  [ 22] setglobal 63 ............................ gSkriver = new(xtra("PrintOMatic"))
  [ 24] getglobal 63 ............................ <gSkriver>
  [ 26] pusharglist 1 ........................... <gSkriver>
  [ 28] extcall 62 .............................. <objectp(gSkriver)>
  [ 30] jmpifz [ 55] ............................ if objectp(gSkriver) then
  [ 33] getglobal 63 ............................ <gSkriver>
  [ 35] pushcons 1 .............................. <"Printing from Josefine...">
  [ 37] pusharglistnoret 2 ...................... <gSkriver, "Printing from Josefine...">
  [ 39] extcall 66 .............................. setProgressMsg(gSkriver, "Printing from Josefine...")
  [ 41] getglobal 63 ............................ <gSkriver>
  [ 43] pushcons 2 .............................. <"JOSEFINE">
  [ 45] pusharglistnoret 2 ...................... <gSkriver, "JOSEFINE">
  [ 47] extcall 67 .............................. setDocumentName(gSkriver, "JOSEFINE")
  [ 49] getglobal 63 ............................ <gSkriver>
  [ 51] pusharglistnoret 1 ...................... <gSkriver>
  [ 53] extcall 68 .............................. reset(gSkriver)
  [ 55] ret
end

on DisposePrinter
  [  0] getglobal 63 ............................ <gSkriver>
  [  2] pusharglist 1 ........................... <gSkriver>
  [  4] extcall 62 .............................. <objectp(gSkriver)>
  [  6] jmpifz [ 12] ............................ if objectp(gSkriver) then
  [  9] pushzero ................................ <0>
  [ 10] setglobal 63 ............................ gSkriver = 0
  [ 12] ret
end

on CopyrightText
  [  0] getglobal 63 ............................ <gSkriver>
  [  2] pusharglist 1 ........................... <gSkriver>
  [  4] extcall 69 .............................. <getPageHeight(gSkriver)>
  [  6] setlocal 0 .............................. heigth = getPageHeight(gSkriver)
  [  8] getglobal 63 ............................ <gSkriver>
  [ 10] pushint8 8 .............................. <8>
  [ 12] pusharglistnoret 2 ...................... <gSkriver, 8>
  [ 14] extcall 70 .............................. setTextSize(gSkriver, 8)
  [ 16] getglobal 63 ............................ <gSkriver>
  [ 18] pushcons 3 .............................. <"centered">
  [ 20] pusharglistnoret 2 ...................... <gSkriver, "centered">
  [ 22] extcall 71 .............................. setTextJust(gSkriver, "centered")
  [ 24] getglobal 63 ............................ <gSkriver>
  [ 26] pushint8 100 ............................ <100>
  [ 28] pusharglistnoret 2 ...................... <gSkriver, 100>
  [ 30] extcall 72 .............................. setGray(gSkriver, 100)
  [ 32] getglobal 63 ............................ <gSkriver>
  [ 34] pushzero ................................ <0>
  [ 35] getlocal 0 .............................. <heigth>
  [ 37] pushint8 40 ............................. <40>
  [ 39] sub ..................................... <heigth - 40>
  [ 40] pushint8 100 ............................ <100>
  [ 42] getlocal 0 .............................. <heigth>
  [ 44] pusharglist 4 ........................... <0, heigth - 40, 100, heigth>
  [ 46] extcall 14 .............................. <rect(0, heigth - 40, 100, heigth)>
  [ 48] pushzero ................................ <0>
  [ 49] pusharglistnoret 3 ...................... <gSkriver, rect(0, heigth - 40, 100, heigth), 0>
  [ 51] extcall 73 .............................. newFrame(gSkriver, rect(0, heigth - 40, 100, heigth), 0)
  [ 53] getglobal 63 ............................ <gSkriver>
  [ 55] pushcons 4 .............................. <"TheCopyrightText">
  [ 57] getglobal 76 ............................ <gLanguage>
  [ 59] joinstr ................................. <"TheCopyrightText" & gLanguage>
  [ 60] pusharglist 1 ........................... <"TheCopyrightText" & gLanguage>
  [ 62] extcall 75 .............................. <cast("TheCopyrightText" & gLanguage)>
  [ 64] getobjprop 77 ........................... <cast("TheCopyrightText" & gLanguage).text>
  [ 66] pusharglistnoret 2 ...................... <gSkriver, cast("TheCopyrightText" & gLanguage).text>
  [ 68] extcall 74 .............................. append(gSkriver, cast("TheCopyrightText" & gLanguage).text)
  [ 70] ret
end
