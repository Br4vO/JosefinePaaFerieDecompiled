on exitFrame
  [  0] pushcons 0 .............................. <"Hand1">
  [  2] pushzero ................................ <0>
  [  3] pushint16 10 ............................ <10>
  [  6] get 9 ................................... <the number of member "Hand1">
  [  8] setlocal 0 .............................. haand = the number of member "Hand1"
  [ 10] pushcons 1 .............................. <"Mask1">
  [ 12] pushzero ................................ <0>
  [ 13] pushint16 10 ............................ <10>
  [ 16] get 9 ................................... <the number of member "Mask1">
  [ 18] setlocal 1 .............................. maske = the number of member "Mask1"
  [ 20] pushint16 3 ............................. <3>
  [ 23] setlocal 2 .............................. i = 3
  [ 25] getlocal 2 .............................. <i>
  [ 27] pushint16 7 ............................. <7>
  [ 30] lteq .................................... <i <= 7>
  [ 31] jmpifz [ 58] ............................ repeat while i <= 7
  [ 34] getlocal 2 .............................. <i>
  [ 36] getlocal 0 .............................. <haand>
  [ 38] getlocal 1 .............................. <maske>
  [ 40] pusharglist 2 ........................... <[haand, maske]>
  [ 42] pushlist ................................ <[haand, maske]>
  [ 43] pushint16 6 ............................. <6>
  [ 46] set 6 ................................... set the cursor of sprite i to [haand, maske]
  [ 48] pushint16 1 ............................. <1>
  [ 51] getlocal 2 .............................. <i>
  [ 53] add ..................................... <1 + i>
  [ 54] setlocal 2 .............................. i = 1 + i
  [ 56] endrepeat [ 25]
  [ 58] ret
end
